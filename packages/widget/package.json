{
  "name": "@helpnest/widget",
  "version": "0.1.0",
  "description": "Embeddable help widget for HelpNest — AI chat and article search for any website",
  "license": "MIT",
  "author": "Sharan Karthikeyan <karthikeyansharan00@gmail.com>",
  "homepage": "https://helpnest.cloud/",
  "repository": {
    "type": "git",
    "url": "https://github.com/babble-open-source/helpnest.git",
    "directory": "packages/widget"
  },
  "bugs": {
    "url": "https://github.com/babble-open-source/helpnest/issues"
  },
  "keywords": [
    "helpnest",
