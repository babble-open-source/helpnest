{
  "name": "@helpnest/sdk",
  "version": "0.3.1",
  "private": false,
  "description": "JavaScript/TypeScript SDK for HelpNest — the open-source AI-first customer support platform",
  "license": "MIT",
  "author": "Sharan Karthikeyan <karthikeyansharan00@gmail.com>",
  "homepage": "https://helpnest.cloud/",
  "repository": {
    "type": "git",
    "url": "https://github.com/babble-open-source/helpnest.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/babble-open-source/helpnest/issues"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "pnpm test && pnpm build"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {},
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "@vitest/coverage-v8": "^1.6.0"
  },
  "keywords": [
    "helpnest",
    "sdk",
    "customer-support",
    "ai-first",
    "help-center",
    "knowledge-base",
    "conversations",
    "escalation",
    "self-hosted",
    "open-source"
  ]
}
