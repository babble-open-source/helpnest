{
  "name": "@helpnest/mcp",
  "version": "0.1.0",
  "private": false,
  "description": "MCP server for HelpNest — expose your knowledge base to AI assistants",
  "homepage": "https://github.com/babble-open-source/helpnest",
  "repository": {
    "type": "git",
    "url": "https://github.com/babble-open-source/helpnest.git",
    "directory": "packages/mcp"
  },
  "bugs": {
    "url": "https://github.com/babble-open-source/helpnest/issues"
  },
  "license": "MIT",
  "bin": {
    "helpnest-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@helpnest/sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "keywords": ["helpnest", "mcp", "model-context-protocol", "ai", "knowledge-base"]
}
