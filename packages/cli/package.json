{
  "name": "@helpnest/cli",
  "version": "0.1.0",
  "description": "Official CLI for HelpNest — workspace setup, content import/export, deployment, and AI article drafting",
  "license": "MIT",
  "homepage": "https://github.com/babble-open-source/helpnest",
  "repository": {
    "type": "git",
    "url": "https://github.com/babble-open-source/helpnest.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/babble-open-source/helpnest/issues"
  },
  "keywords": [
    "helpnest",
    "cli",
    "customer-support",
    "help-center",
    "knowledge-base",
    "ai-first",
    "self-hosted",
    "open-source"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": ["dist"],
  "bin": {
    "helpnest": "./dist/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@prisma/client": "^5.13.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "execa": "^8.0.1",
    "inquirer": "^9.2.0",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.0.0",
    "prisma": "^5.13.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
