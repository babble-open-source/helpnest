generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MemberRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ArticleFeedbackType {
  HELPFUL
  NOT_HELPFUL
}

enum ConversationStatus {
  ACTIVE
  ESCALATED
  HUMAN_ACTIVE
  RESOLVED_AI
  RESOLVED_HUMAN
  CLOSED
}

enum MessageRole {
  CUSTOMER
  AI
  AGENT
  SYSTEM
}

enum AiProvider {
  ANTHROPIC
  OPENAI
  GOOGLE
  MISTRAL
}

model Workspace {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  logo         String?
  brandText    String?
  favicon      String?
  customDomain String?
  metaTitle    String?
  metaDescription String?
  themeId      String   @default("default")
  fontPresetId String?
  customCreamColor         String?
  customInkColor           String?
  customMutedColor         String?
  customBorderColor        String?
  customAccentColor        String?
  customGreenColor         String?
  customWhiteColor         String?
  customRadius             String?
  customHeadingFontFamily String?
  customHeadingFontUrl    String?
  customBodyFontFamily    String?
  customBodyFontUrl       String?
  customBrandFontFamily   String?
  customBrandFontUrl      String?
  aiEnabled                Boolean    @default(false)
  aiProvider               AiProvider?
  aiModel                  String?
  aiApiKey                 String?
  aiGreeting               String?
  aiInstructions           String?    @db.Text
  aiEscalationThreshold    Float      @default(0.3)
  autoDraftGapsEnabled      Boolean    @default(true)
  autoDraftGapThreshold     Int        @default(2)
  autoDraftExternalEnabled  Boolean    @default(true)
  batchWindowMinutes        Int        @default(60)
  productContext            String?    @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  collections   Collection[]
  articles      Article[]
  members       Member[]
  apiKeys       ApiKey[]
  searchIndex   SearchIndex[]
  feedback      ArticleFeedback[]
  invites       Invite[]
  conversations Conversation[]
  knowledgeGaps KnowledgeGap[]

  @@index([slug])
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  name              String?
  avatar            String?
  passwordHash      String?
  passwordChangedAt DateTime?
  createdAt         DateTime  @default(now())

  members          Member[]
  articles         Article[]
  articleVersions  ArticleVersion[]
  invitesSent      Invite[]
  resolvedGaps     KnowledgeGap[]
}

model Member {
  id             String     @id @default(cuid())
  workspaceId    String
  userId         String
  role           MemberRole @default(VIEWER)
  deactivatedAt  DateTime?

  workspace            Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user                 User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedConversations Conversation[]

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

model Collection {
  id          String  @id @default(cuid())
  workspaceId String
  title       String
  description String?
  icon        String?
  emoji       String?
  slug        String
  order       Int     @default(0)
  isPublic    Boolean @default(true)
  isArchived  Boolean @default(false)
  parentId    String?

  workspace        Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parent           Collection?  @relation("SubCollections", fields: [parentId], references: [id])
  subCollections   Collection[] @relation("SubCollections")
  articles         Article[]

  @@unique([workspaceId, slug])
  @@index([workspaceId])
  @@index([parentId])
}

model Article {
  id           String        @id @default(cuid())
  workspaceId  String
  collectionId String
  title        String
  slug         String
  content      String        @db.Text
  draftContent String?       @db.Text
  excerpt      String?
  status       ArticleStatus @default(DRAFT)
  order        Int           @default(0)
  views        Int           @default(0)
  helpful      Int           @default(0)
  notHelpful   Int           @default(0)
  isSeeded     Boolean       @default(false)
  aiGenerated  Boolean       @default(false)
  aiPrompt     String?       @db.Text
  authorId     String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  publishedAt  DateTime?

  workspace        Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  collection       Collection            @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  author           User                  @relation(fields: [authorId], references: [id])
  versions         ArticleVersion[]
  searchIndex      SearchIndex[]
  feedback         ArticleFeedback[]
  conversationRefs ConversationArticle[]
  resolvedGaps     KnowledgeGap[]

  @@unique([workspaceId, slug])
  @@index([workspaceId])
  @@index([collectionId])
  @@index([status])
  @@index([workspaceId, status])
}

model ArticleVersion {
  id        String   @id @default(cuid())
  articleId String
  content   String   @db.Text
  title     String
  createdAt DateTime @default(now())
  authorId  String
  version   Int

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorId], references: [id])

  @@unique([articleId, version])
  @@index([articleId])
}

model ApiKey {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  keyHash     String    @unique
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([keyHash])
}

model SearchIndex {
  id          String   @id @default(cuid())
  articleId   String
  workspaceId String
  embedding   Json?
  updatedAt   DateTime @updatedAt

  article   Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([articleId])
  @@index([workspaceId])
}

model ArticleFeedback {
  id         String              @id @default(cuid())
  articleId  String
  workspaceId String
  voterToken String
  type       ArticleFeedbackType
  userAgent  String?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  article   Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([articleId, voterToken])
  @@index([workspaceId, createdAt])
  @@index([articleId, type])
}

model Invite {
  id          String     @id @default(cuid())
  workspaceId String
  email       String
  role        MemberRole @default(EDITOR)
  token       String     @unique @default(cuid())
  invitedById String
  acceptedAt  DateTime?
  expiresAt   DateTime
  createdAt   DateTime   @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy User      @relation(fields: [invitedById], references: [id])

  @@index([workspaceId])
  @@index([token])
}

model Conversation {
  id                 String             @id @default(cuid())
  workspaceId        String
  status             ConversationStatus @default(ACTIVE)
  customerName       String?
  customerEmail      String?
  sessionToken       String             @unique @default(cuid())
  subject            String?
  assignedToId       String?
  aiConfidence       Float?
  escalationReason   String?
  resolutionSummary  String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  workspace  Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assignedTo Member?              @relation(fields: [assignedToId], references: [id])
  messages   Message[]
  articles   ConversationArticle[]

  @@index([workspaceId, status])
  @@index([workspaceId, createdAt])
  @@index([assignedToId])
}

model Message {
  id               String      @id @default(cuid())
  conversationId   String
  role             MessageRole
  content          String      @db.Text
  sources          Json?
  confidence       Float?
  feedbackHelpful  Boolean?
  createdAt        DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model ConversationArticle {
  id             String @id @default(cuid())
  conversationId String
  articleId      String

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  article      Article      @relation(fields: [articleId], references: [id])

  @@unique([conversationId, articleId])
  @@index([articleId])
}

model KnowledgeGap {
  id                String    @id @default(cuid())
  workspaceId       String
  query             String
  queryHash         String
  occurrences       Int       @default(1)
  lastSeenAt        DateTime  @default(now())
  resolvedAt        DateTime?
  resolvedById      String?
  resolvedArticleId String?
  createdAt         DateTime  @default(now())

  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  resolvedBy      User?     @relation(fields: [resolvedById], references: [id])
  resolvedArticle Article?  @relation(fields: [resolvedArticleId], references: [id])

  @@unique([workspaceId, queryHash])
  @@index([workspaceId, resolvedAt])
  @@index([workspaceId, occurrences])
}
