generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MemberRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ArticleFeedbackType {
  HELPFUL
  NOT_HELPFUL
}

enum ConversationStatus {
  ACTIVE
  ESCALATED
  HUMAN_ACTIVE
  RESOLVED_AI
  RESOLVED_HUMAN
  CLOSED
}

enum MessageRole {
  CUSTOMER
  AI
  AGENT
  SYSTEM
}

enum AiProvider {
  ANTHROPIC
  OPENAI
  GOOGLE
  MISTRAL
}

enum CollectionVisibility {
  PUBLIC
  INTERNAL
}

enum CrawlMode {
  SINGLE
  DEEP
  FLOW
}

enum CrawlJobStatus {
  PENDING
  CRAWLING
  EXTRACTING
  GENERATING
  COMPLETED
  FAILED
}

enum CrawlPageStatus {
  PENDING
  FETCHED
  EXTRACTED
  GENERATED
  SKIPPED
  FAILED
}

enum VerificationMethod {
  META_TAG
  DNS_TXT
}

enum ContactOrgSource {
  DOMAIN
  MANUAL
  API
  CRM
  BACKFILL
}

enum ContactOrgRole {
  MEMBER
  ADMIN
  TECHNICAL
  BILLING
}

enum EventActorType {
  CUSTOMER
  AI
  AGENT
  SYSTEM
}

enum ConversationEventVerb {
  CONVERSATION_CREATED
  STATUS_CHANGED
  ASSIGNED
  UNASSIGNED
  CONTACT_LINKED
  ORG_LINKED
  FIRST_RESPONSE_SENT
  NOTE_ADDED
  AI_ANSWERED
  AI_ESCALATED
  HANDOFF_TO_HUMAN
  RESOLVED
  REOPENED
}

model Workspace {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  logo         String?
  brandText    String?
  favicon      String?
  customDomain String?
  metaTitle    String?
  metaDescription String?
  themeId      String   @default("default")
  fontPresetId String?
  customCreamColor         String?
  customInkColor           String?
  customMutedColor         String?
  customBorderColor        String?
  customAccentColor        String?
  customGreenColor         String?
  customWhiteColor         String?
  customRadius             String?
  customHeadingFontFamily String?
  customHeadingFontUrl    String?
  customBodyFontFamily    String?
  customBodyFontUrl       String?
  customBrandFontFamily   String?
  customBrandFontUrl      String?
  aiEnabled                Boolean    @default(false)
  aiProvider               AiProvider?
  aiModel                  String?
  aiApiKey                 String?
  aiGreeting               String?
  aiInstructions           String?    @db.Text
  aiEscalationThreshold    Float      @default(0.3)
  autoDraftGapsEnabled      Boolean    @default(true)
  autoDraftGapThreshold     Int        @default(2)
  autoDraftExternalEnabled  Boolean    @default(true)
  batchWindowMinutes        Int        @default(60)
  aiDraftRateLimit          Int        @default(50)
  aiCreditsUsed             Int        @default(0)
  aiCreditsLimit            Int        @default(5)
  productContext            String?    @db.Text
  widgetResponseTime        String?
  // Voice
  voiceEnabled      Boolean  @default(false)
  voiceGreeting     String?
  voiceLanguage     String?  @default("en")
  voiceSettings     Json?
  voiceMinutesUsed  Int      @default(0)
  voiceSessions     VoiceSession[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  collections   Collection[]
  articles      Article[]
  members       Member[]
  apiKeys       ApiKey[]
  searchIndex   SearchIndex[]
  feedback      ArticleFeedback[]
  invites       Invite[]
  conversations Conversation[]
  knowledgeGaps KnowledgeGap[]
  crawlJobs     CrawlJob[]
  domainVerifications DomainVerification[]
  contacts              Contact[]
  organizations         Organization[]
  workspaceCounter      WorkspaceCounter?
  conversationEvents    ConversationEvent[]

  deletedAt DateTime?

  @@index([slug])
  @@index([deletedAt])
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  name              String?
  avatar            String?
  passwordHash      String?
  passwordChangedAt DateTime?
  createdAt         DateTime  @default(now())

  members          Member[]
  articles         Article[]
  articleVersions  ArticleVersion[]
  invitesSent      Invite[]
  resolvedGaps     KnowledgeGap[]
  crawlJobs        CrawlJob[]
}

model Member {
  id             String     @id @default(cuid())
  workspaceId    String
  userId         String
  role           MemberRole @default(VIEWER)
  deactivatedAt  DateTime?

  workspace            Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user                 User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedConversations Conversation[]
  ownedOrganizations    Organization[]      @relation("OrgOwner")
  conversationEvents    ConversationEvent[]
  messageAuthored       Message[]

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

model Collection {
  id          String  @id @default(cuid())
  workspaceId String
  title       String
  description String?
  icon        String?
  emoji       String?
  slug        String
  order       Int     @default(0)
  visibility  CollectionVisibility @default(PUBLIC)
  isArchived  Boolean @default(false)
  parentId    String?

  workspace        Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parent           Collection?  @relation("SubCollections", fields: [parentId], references: [id])
  subCollections   Collection[] @relation("SubCollections")
  articles         Article[]

  @@unique([workspaceId, slug])
  @@index([workspaceId])
  @@index([parentId])
}

model Article {
  id           String        @id @default(cuid())
  workspaceId  String
  collectionId String
  title        String
  slug         String
  content      String        @db.Text
  draftContent String?       @db.Text
  excerpt      String?
  status       ArticleStatus @default(DRAFT)
  order        Int           @default(0)
  views        Int           @default(0)
  helpful      Int           @default(0)
  notHelpful   Int           @default(0)
  isSeeded     Boolean       @default(false)
  aiGenerated  Boolean       @default(false)
  aiPrompt     String?       @db.Text
  authorId     String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  publishedAt  DateTime?

  workspace        Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  collection       Collection            @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  author           User                  @relation(fields: [authorId], references: [id])
  versions         ArticleVersion[]
  searchIndex      SearchIndex[]
  feedback         ArticleFeedback[]
  conversationRefs ConversationArticle[]
  resolvedGaps     KnowledgeGap[]
  crawlPage        CrawlPage?

  @@unique([workspaceId, slug])
  @@index([workspaceId])
  @@index([collectionId])
  @@index([status])
  @@index([workspaceId, status])
}

model ArticleVersion {
  id        String   @id @default(cuid())
  articleId String
  content   String   @db.Text
  title     String
  createdAt DateTime @default(now())
  authorId  String
  version   Int

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorId], references: [id])

  @@unique([articleId, version])
  @@index([articleId])
}

model ApiKey {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  keyHash     String    @unique
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([keyHash])
}

model SearchIndex {
  id          String   @id @default(cuid())
  articleId   String
  workspaceId String
  embedding   Json?
  updatedAt   DateTime @updatedAt

  article   Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([articleId])
  @@index([workspaceId])
}

model ArticleFeedback {
  id         String              @id @default(cuid())
  articleId  String
  workspaceId String
  voterToken String
  type       ArticleFeedbackType
  userAgent  String?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  article   Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([articleId, voterToken])
  @@index([workspaceId, createdAt])
  @@index([articleId, type])
}

model Invite {
  id          String     @id @default(cuid())
  workspaceId String
  email       String
  role        MemberRole @default(EDITOR)
  token       String     @unique @default(cuid())
  invitedById String
  acceptedAt  DateTime?
  expiresAt   DateTime
  createdAt   DateTime   @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy User      @relation(fields: [invitedById], references: [id])

  @@index([workspaceId])
  @@index([token])
}

model Conversation {
  id                 String             @id @default(cuid())
  workspaceId        String
  status             ConversationStatus @default(ACTIVE)
  customerName       String?
  customerEmail      String?
  sessionToken       String             @unique @default(cuid())
  visitorId          String?
  subject            String?
  assignedToId       String?
  number         Int?
  contactId      String?
  organizationId String?
  aiConfidence       Float?
  escalationReason   String?
  resolutionSummary  String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  workspace     Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assignedTo    Member?              @relation(fields: [assignedToId], references: [id])
  messages      Message[]
  articles      ConversationArticle[]
  voiceSessions VoiceSession[]
  contact      Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  events       ConversationEvent[]

  @@index([workspaceId, status])
  @@index([workspaceId, createdAt])
  @@index([assignedToId])
  @@index([workspaceId, visitorId])
  @@index([workspaceId, number])
  @@index([workspaceId, contactId])
  @@index([workspaceId, organizationId])
}

model VoiceSession {
  id              String        @id @default(cuid())
  workspaceId     String
  workspace       Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversationId  String?
  conversation    Conversation? @relation(fields: [conversationId], references: [id])
  roomName        String        @unique
  startedAt       DateTime      @default(now())
  endedAt         DateTime?
  durationSeconds Int?
  status          String        @default("active")
  createdAt       DateTime      @default(now())

  @@index([workspaceId])
  @@index([roomName])
}

model Message {
  id               String      @id @default(cuid())
  conversationId   String
  role             MessageRole
  content          String      @db.Text
  sources          Json?
  confidence       Float?
  isInternal       Boolean  @default(false)
  authorMemberId   String?
  feedbackHelpful  Boolean?
  createdAt        DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  authorMember Member? @relation(fields: [authorMemberId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([conversationId, isInternal])
}

model ConversationArticle {
  id             String @id @default(cuid())
  conversationId String
  articleId      String

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  article      Article      @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([conversationId, articleId])
  @@index([articleId])
}

model KnowledgeGap {
  id                String    @id @default(cuid())
  workspaceId       String
  query             String
  queryHash         String
  occurrences       Int       @default(1)
  lastSeenAt        DateTime  @default(now())
  resolvedAt        DateTime?
  resolvedById      String?
  resolvedArticleId String?
  createdAt         DateTime  @default(now())

  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  resolvedBy      User?     @relation(fields: [resolvedById], references: [id])
  resolvedArticle Article?  @relation(fields: [resolvedArticleId], references: [id])

  @@unique([workspaceId, queryHash])
  @@index([workspaceId, resolvedAt])
  @@index([workspaceId, occurrences])
}

model CrawlJob {
  id              String         @id @default(cuid())
  workspaceId     String
  userId          String
  sourceUrl       String
  goalPrompt      String         @default("") @db.Text
  discoveredUrls  Json?
  approvedUrls    Json?
  mode            CrawlMode      @default(SINGLE)
  status          CrawlJobStatus @default(PENDING)
  config          Json?
  totalPages      Int            @default(0)
  processedPages  Int            @default(0)
  articlesCreated Int            @default(0)
  error           String?
  createdAt       DateTime       @default(now())
  completedAt     DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id])
  pages     CrawlPage[]

  @@index([workspaceId])
  @@index([status])
}

model CrawlPage {
  id               String          @id @default(cuid())
  crawlJobId       String
  url              String
  status           CrawlPageStatus @default(PENDING)
  contentType      String?
  language         String?
  rawContent       String?         @db.Text
  articleId        String?         @unique
  similarArticleId String?
  skipReason       String?
  createdAt        DateTime        @default(now())

  crawlJob CrawlJob @relation(fields: [crawlJobId], references: [id], onDelete: Cascade)
  article  Article? @relation(fields: [articleId], references: [id])

  @@index([crawlJobId])
}

model DomainVerification {
  id          String             @id @default(cuid())
  workspaceId String
  domain      String
  method      VerificationMethod
  token       String
  verifiedAt  DateTime?
  createdAt   DateTime           @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, domain])
  @@index([workspaceId])
}

model Contact {
  id           String    @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  externalId   String?
  email        String?
  fullName     String?
  phone        String?
  avatarUrl    String?
  visitorId    String?
  customFields Json?     @default("{}")
  mergedIntoId String?
  mergedInto   Contact?  @relation("ContactMerge", fields: [mergedIntoId], references: [id], onDelete: SetNull)
  mergedFrom   Contact[] @relation("ContactMerge")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  organizations ContactOrganization[]
  conversations Conversation[]

  @@unique([workspaceId, email])
  @@unique([workspaceId, externalId])
  @@unique([workspaceId, visitorId])
  @@index([workspaceId])
}

model Organization {
  id           String    @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  externalId   String?
  name         String
  domains      String[]
  plan         String?
  tags         String[]  @default([])
  notes        String?
  customFields Json?     @default("{}")
  ownerId      String?
  owner        Member?   @relation("OrgOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  contacts      ContactOrganization[]
  conversations Conversation[]

  @@unique([workspaceId, externalId])
  @@index([workspaceId])
  @@index([workspaceId, ownerId])
}

model ContactOrganization {
  id             String           @id @default(cuid())
  workspaceId    String
  contactId      String
  organizationId String
  isPrimary      Boolean          @default(false)
  role           ContactOrgRole?
  source         ContactOrgSource @default(MANUAL)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  contact      Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([contactId, organizationId])
  @@index([workspaceId, organizationId])
  @@index([workspaceId, contactId])
}

model WorkspaceCounter {
  workspaceId            String    @id
  lastConversationNumber Int       @default(0)
  workspace              Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model ConversationEvent {
  id             String                @id @default(cuid())
  workspaceId    String
  conversationId String
  actorType      EventActorType
  actorMemberId  String?
  actorLabel     String?
  verb           ConversationEventVerb
  payload        Json?
  durationSeconds         Int?
  durationBusinessSeconds Int?
  createdAt      DateTime              @default(now())
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  actorMember  Member?      @relation(fields: [actorMemberId], references: [id], onDelete: NoAction)

  @@index([conversationId, createdAt])
  @@index([workspaceId, verb, createdAt])
  @@index([workspaceId, createdAt])
}
