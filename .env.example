# ══════════════════════════════════════════════════════════════════════════════
# HelpNest — Environment Variables
# Copy this file to .env and fill in the values.
# self-host-setup.sh auto-generates secrets for Docker deployments.
# ══════════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────────
# Local development: use localhost
DATABASE_URL=postgresql://helpnest:helpnest@localhost:5432/helpnest_dev

# Docker / self-hosted production (docker-compose.prod.yml):
# Use the Docker service name "postgres" and match POSTGRES_PASSWORD below.
# DATABASE_URL=postgresql://helpnest:CHANGE_ME@postgres:5432/helpnest

# Tune the connection pool for production (optional):
#   DATABASE_URL=...?connection_limit=10&pool_timeout=20

# PostgreSQL password — required by docker-compose.prod.yml.
# self-host-setup.sh auto-generates this value.
POSTGRES_PASSWORD=

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=run-openssl-rand-base64-32-to-generate

# Seed credentials — used once when running db:seed.
# Both default to well-known dev values ('admin@helpnest.cloud' / 'helpnest')
# which are public in the OSS repo. Always set ADMIN_SEED_PASSWORD before
# running db:seed in production. self-host-setup.sh auto-generates this.
ADMIN_SEED_EMAIL=
ADMIN_SEED_PASSWORD=

NEXTAUTH_URL=http://localhost:3000

# ── GitHub OAuth (optional) ───────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Google OAuth (optional) ──────────────────────────────────────────────────
# Get credentials from Google Cloud Console → APIs & Services → Credentials
# Authorized redirect URI: https://your-domain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Redis ─────────────────────────────────────────────────────────────────────
# Required for distributed rate limiting in multi-instance deployments.
# Leave unset for single-server self-hosted — falls back to in-memory rate limiting.
#
# Local development:
REDIS_URL=redis://localhost:6379
# Docker production: use service name "redis" and include the password.
# REDIS_URL=redis://:CHANGE_ME@redis:6379
#
# Redis password for docker-compose.prod.yml. self-host-setup.sh auto-generates this.
REDIS_PASSWORD=

# ── AI Features (optional) ────────────────────────────────────────────────────
# Without these, search falls back to Postgres full-text search.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Rate limit for AI repo analysis endpoint (requests per workspace per hour).
# Default is 5. Self-hosted instances can raise or remove this limit.
# Set to 0 to disable rate limiting entirely.
ANALYZE_REPO_RATE_LIMIT=

# ── Storage (for image uploads, optional) ─────────────────────────────────────
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
# Public URL of this app. Baked into the client bundle at build time —
# pass as a Docker build arg: --build-arg NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Help center subdomain routing (cloud / production) ────────────────────────
# Subdomains like support.helpnest.cloud → /support/help
# Leave unset in local dev; direct URL access /{slug}/help works without it.
NEXT_PUBLIC_HELP_CENTER_DOMAIN=helpnest.cloud

# ── AI key encryption ─────────────────────────────────────────────────────────
# Secret used to encrypt workspace AI API keys at rest.
# Generate with: openssl rand -base64 32
AI_KEY_ENCRYPTION_SECRET=

# ── Demo / showcase mode ──────────────────────────────────────────────────────
# Set to "true" to always show default credentials on the login page and
# suppress the "change your password" banner in the dashboard.
# Useful for live demos, conference showcases, or staging environments where
# the default password is intentional.
HELPNEST_DEMO_MODE=

# ── HelpNest Cloud integration (optional) ───────────────────────────────────
# Set these ONLY when running as part of HelpNest Cloud.
# Leave unset for self-hosted deployments — signup, billing, and limits
# are disabled and the app runs fully standalone.
#
# Internal URL of the cloud billing service (server-side only, never exposed to browsers)
# CLOUD_API_URL=http://localhost:3002
#
# Public URL of the cloud marketing site (client-side, used for sidebar billing link)
# NEXT_PUBLIC_CLOUD_URL=http://localhost:3002
#
# Shared secret for inter-service auth (must match INTERNAL_SECRET in cloud .env)
# INTERNAL_SECRET=changeme-at-least-16-chars

# ── Custom domain for self-hosted deployments ─────────────────────────────────
# Map a custom domain → a workspace slug so support.yourdomain.com serves
# that workspace's help center at the root (no /slug/help prefix needed).
HELPNEST_CUSTOM_DOMAIN=
HELPNEST_CUSTOM_DOMAIN_SLUG=
