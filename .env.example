# Database
DATABASE_URL=postgresql://helpnest:helpnest@localhost:5432/helpnest_dev

# Auth
AUTH_SECRET=run-openssl-rand-base64-32-to-generate
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# AI Features (Phase 4)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Storage (for image uploads)
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Help center subdomain routing (production)
# Subdomains like support.helpnest.cloud → /support/help
# Leave unset in local dev; direct URL access /{slug}/help works without it.
NEXT_PUBLIC_HELP_CENTER_DOMAIN=helpnest.cloud
