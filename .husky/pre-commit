#!/usr/bin/env sh

# 1. Lint + format staged files
pnpm exec lint-staged || exit 1

# 2. Type-check across workspaces
echo "→ Running type-check..."
pnpm typecheck || exit 1

# 3. Build (catches issues that type-check alone misses — imports, config, etc.)
echo "→ Running build..."
pnpm build || exit 1
